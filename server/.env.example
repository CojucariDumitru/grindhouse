NODE_ENV=development
PORT=5000

# Postgres connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=reservations@grindhouse.com
RESTAURANT_EMAIL=admin@grindhouse.com

# Cloudinary (menu item images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — the deployed frontend origin
CLIENT_URL=http://localhost:5173

# Seed admin credentials
ADMIN_EMAIL=admin@grindhouse.com
ADMIN_PASSWORD=Grind2024!
